<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <ProjectOptions>
    <Version Value="12"/>
    <General>
      <SessionStorage Value="InProjectDir"/>
      <Title Value="ZombieTraitStudio"/>
      <Scaled Value="True"/>
      <ResourceType Value="res"/>
      <UseXPManifest Value="True"/>
      <XPManifest>
        <DpiAware Value="True"/>
      </XPManifest>
      <Icon Value="0"/>
    </General>
    <BuildModes>
      <Item Name="Default" Default="True"/>
    </BuildModes>
    <PublishOptions>
      <Version Value="2"/>
      <UseFileFilters Value="True"/>
    </PublishOptions>
    <RunParams>
      <FormatVersion Value="2"/>
    </RunParams>
    <RequiredPackages>
      <Item>
        <PackageName Value="LCL"/>
      </Item>
    </RequiredPackages>
    <Units>
      <Unit>
        <Filename Value="ZombieTraitStudio.lpr"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="source/forms/umain.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="MainForm"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="Form"/>
        <UnitName Value="uMain"/>
      </Unit>
      <Unit>
        <Filename Value="source/core/ulogger.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uLogger"/>
      </Unit>
      <Unit>
        <Filename Value="source/core/utypes.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uTypes"/>
      </Unit>
      <Unit>
        <Filename Value="source/core/uexceptions.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uExceptions"/>
      </Unit>
      <Unit>
        <Filename Value="source/core/upaths.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uPaths"/>
      </Unit>
      <Unit>
        <Filename Value="source/core/uconfig.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uConfig"/>
      </Unit>
      <Unit>
        <Filename Value="source/core/uapp.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uApp"/>
      </Unit>
      <Unit>
        <Filename Value="source/core/uconsts.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uConsts"/>
      </Unit>
      <Unit>
        <Filename Value="source/core/uenvironment.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uEnvironment"/>
      </Unit>
      <Unit>
        <Filename Value="source/core/uutils.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uUtils"/>
      </Unit>
    </Units>
  </ProjectOptions>
  <CompilerOptions>
    <Version Value="11"/>
    <Target>
      <Filename Value="ZombieTraitStudio"/>
    </Target>
    <SearchPaths>
      <IncludeFiles Value="$(ProjOutDir)"/>
      <OtherUnitFiles Value="source/forms;source/core;source/ai;source/comfy;source/graphics;source/storage;source/utils"/>
      <UnitOutputDirectory Value="lib/$(TargetCPU)-$(TargetOS)"/>
    </SearchPaths>
    <Linking>
      <Debugging>
        <DebugInfoType Value="dsDwarf3"/>
      </Debugging>
      <Options>
        <Win32>
          <GraphicApplication Value="True"/>
        </Win32>
      </Options>
    </Linking>
  </CompilerOptions>
  <Debugging>
    <Exceptions>
      <Item>
        <Name Value="EAbort"/>
      </Item>
      <Item>
        <Name Value="ECodetoolError"/>
      </Item>
      <Item>
        <Name Value="EFOpenError"/>
      </Item>
    </Exceptions>
  </Debugging>
</CONFIG>
