object MainForm: TMainForm
  Left = 300
  Height = 700
  Top = 200
  Width = 1100
  Caption = 'Zombie Trait Studio'
  ClientHeight = 700
  ClientWidth = 1100
  DesignTimePPI = 120
  Font.Height = 18
  Menu = MainMenu
  LCLVersion = '4.6.0.0'
  OnCreate = FormCreate
  OnDestroy = FormDestroy
  object TraitPanel: TPanel
    Left = 5
    Height = 675
    Top = 0
    Width = 260
    Align = alLeft
    ClientHeight = 675
    ClientWidth = 260
    TabOrder = 0
    object TraitList: TListView
      Left = 1
      Height = 673
      Top = 1
      Width = 258
      Align = alClient
      Columns = <      
        item
          Caption = 'Trait'
          Width = 236
        end>
      TabOrder = 0
      ViewStyle = vsReport
      OnSelectItem = TraitListSelectItem
    end
  end
  object TraitSplitter: TSplitter
    Left = 0
    Height = 675
    Top = 0
    Width = 5
  end
  object InfoPanel: TPanel
    Left = 780
    Height = 675
    Top = 0
    Width = 320
    Align = alRight
    ClientHeight = 675
    ClientWidth = 320
    TabOrder = 2
    object TraitInfo: TMemo
      Left = 1
      Height = 673
      Top = 1
      Width = 318
      Align = alClient
      ReadOnly = True
      ScrollBars = ssAutoBoth
      TabOrder = 0
    end
  end
  object InfoSplitter: TSplitter
    Left = 775
    Height = 675
    Top = 0
    Width = 5
    Align = alRight
    ResizeAnchor = akRight
  end
  object ImagePreview: TImage
    Left = 265
    Height = 675
    Top = 0
    Width = 510
    Align = alClient
    Center = True
    Proportional = True
    Stretch = True
  end
  object StatusBar: TStatusBar
    Left = 0
    Height = 25
    Top = 675
    Width = 1100
    Panels = <>
    SimpleText = 'Zombie Trait Studio ready'
  end
  object MainMenu: TMainMenu
    object FileMenu: TMenuItem
      Caption = 'File'
      object OpenImageMenuItem: TMenuItem
        Caption = 'Open Image...'
        OnClick = OpenImageMenuItemClick
      end
      object SeparatorMenuItem: TMenuItem
        Caption = '-'
      end
      object ExitMenuItem: TMenuItem
        Caption = 'Exit'
        OnClick = ExitMenuItemClick
      end
    end
    object ToolsMenu: TMenuItem
      Caption = 'Tools'
      object SettingsMenuItem: TMenuItem
        Caption = 'Settings'
      end
    end
    object HelpMenu: TMenuItem
      Caption = 'Help'
      object AboutMenuItem: TMenuItem
        Caption = 'About'
        OnClick = AboutMenuItemClick
      end
    end
  end
  object OpenPictureDialog: TOpenPictureDialog
    Filter = 'Images|*.png;*.jpg;*.jpeg;*.bmp;*.webp|All files|*.*'
  end
end
